# ==================== APP SETUP ====================
def build_app(token):
    app = Application.builder().token(token).concurrent_updates(True).build()

    app.add_handler(CommandHandler("start", start_cmd))
    app.add_handler(CommandHandler("help", help_cmd))

    # NC commands
    app.add_handler(CommandHandler("nc", nc_cmd))
    app.add_handler(CommandHandler("h", n_cmd))
    app.add_handler(CommandHandler("hcc", ncc_cmd))
    app.add_handler(CommandHandler("stop", stop_cmd))

    # Spam
    app.add_handler(CommandHandler("spam", spam_cmd))
    app.add_handler(CommandHandler("stops", stops_cmd))

    # Slide
    app.add_handler(CommandHandler("slide", slide_cmd))
    app.add_handler(CommandHandler("stopslide", stopslide_cmd))

    # Old target system
    app.add_handler(CommandHandler("aim", aim_cmd))
    app.add_handler(CommandHandler("hold", hold_cmd))

    # Control
    app.add_handler(CommandHandler("speed", speed_cmd))
    app.add_handler(CommandHandler("stat", stat_cmd))
    app.add_handler(CommandHandler("kill", kill_cmd))

    # Sudo
    app.add_handler(CommandHandler("addsudo", addsudo_cmd))
    app.add_handler(CommandHandler("delsudo", delsudo_cmd))
    app.add_handler(CommandHandler("sudolist", sudolist_cmd))

    # Auto-promote handler
    app.add_handler(ChatMemberHandler(auto_promote_bots, ChatMemberHandler.MY_CHAT_MEMBER))

    # Auto replies
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, auto_replies))

    return app

async def run_all_bots():
    global apps, bots

    print("⚡ Initializing SSYCHO Bot...")
    for token in TOKENS:
        if token.strip():
            try:
                app = build_app(token)
                apps.append(app)
                bots.append(app.bot)
            except Exception as e:
                print(f"❌ Init error: {e}")

    print(f"🚀 Starting {len(bots)} bots...")
    for app in apps:
        try:
            await app.initialize()
            await app.start()
            await app.updater.start_polling(drop_pending_updates=True)
        except Exception as e:
            print(f"❌ Start error: {e}")

    print(f"✅ {len(bots)} bots running!")
    print(f"👑 Owner: {OWNER_ID}")
    print(f"👥 Sudo: {len(SUDO_USERS)}")
    print(f"⚡ Speed: {delay}s")
    print(f"🔥 /nc - Raid texts")
    print(f"🦋 /h - Emoji pool")
    print(f"🔢 /hcc - Emoji + counting")
    print(f"⚡ /slide <base> - Slide spam")
    print(f"🛑 /stopslide - Stop slide")
    print(f"🎉 Auto-promote enabled!")

    await asyncio.Event().wait()

if __name__ == "__main__":
    try:
        asyncio.run(run_all_bots())
    except KeyboardInterrupt:
        print("\n🛑 Shutting down...")
    except Exception as e:
        print(f"❌ Error: {e}")
