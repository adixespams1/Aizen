async def nc_raid_loop(bot, chat_id, base):
    """NC with RAID TEXTS"""
    i = 0
    while True:
        try:
            patterns = [
                f"{base} {RAID_TEXTS[i % len(RAID_TEXTS)]}",
                f"{RAID_TEXTS[i % len(RAID_TEXTS)]} {base}",
                f"{base}{RAID_TEXTS[i % len(RAID_TEXTS)]}",
                f"{RAID_TEXTS[(i+1) % len(RAID_TEXTS)]} {base}",
                f"{base} {RAID_TEXTS[(i+2) % len(RAID_TEXTS)]}",
            ]

            for j in range(5):
                await bot.set_chat_title(chat_id, patterns[j])
                await asyncio.sleep(0.01)

            i += 1
            await asyncio.sleep(delay)
        except Exception as e:
            await asyncio.sleep(0.5)

