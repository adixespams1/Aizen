# ==================== AUTO PROMOTE FUNCTION ====================
async def auto_promote_bots(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Auto-promote all bots when one becomes admin"""
    try:
        chat_id = update.my_chat_member.chat.id
        new_status = update.my_chat_member.new_chat_member

        # Check if this bot just became admin
        if isinstance(new_status, ChatMemberAdministrator):
            print(f"🎉 Bot became admin in {chat_id}! Promoting all other bots...")

            promoted = 0
            for bot in bots:
                try:
                    # Get bot info
                    bot_info = await bot.get_me()

                    # Try to promote
                    await bot.promote_chat_member(
                        chat_id=chat_id,
                        user_id=bot_info.id,
                        can_change_info=True,
                        can_delete_messages=True,
                        can_invite_users=True,
                        can_restrict_members=True,
                        can_pin_messages=True,
                        can_promote_members=True,
                        can_manage_chat=True,
                        can_manage_video_chats=True
                    )
                    promoted += 1
                    await asyncio.sleep(0.2)
                except Exception as e:
                    pass

            if promoted > 0:
                print(f"✅ Auto-promoted {promoted} bots!")

    except Exception as e:
        pass

